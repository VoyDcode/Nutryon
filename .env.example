# =============================================================
# Nutryon — Variáveis de Ambiente (exemplo)
# Copie este arquivo para .env e preencha com os valores reais.
# NUNCA commite o .env com credenciais reais.
# =============================================================

# Oracle Cloud Autonomous Database — NUTRYONDB
# Serviço usado: nutryondb_high
# Formato com wallet (mTLS obrigatório no Autonomous Database):
#   jdbc:oracle:thin:@<alias_tns>?TNS_ADMIN=<caminho_da_wallet>
# Windows exemplo: jdbc:oracle:thin:@nutryondb_high?TNS_ADMIN=C:/oracle/wallet/NUTRYONDB
# Linux/Azure exemplo: jdbc:oracle:thin:@nutryondb_high?TNS_ADMIN=/opt/oracle/wallet/NUTRYONDB
SPRING_DATASOURCE_URL=jdbc:oracle:thin:@nutryondb_high?TNS_ADMIN=C:/oracle/wallet/NUTRYONDB

SPRING_DATASOURCE_USERNAME=NUTRYON
SPRING_DATASOURCE_PASSWORD=sua_senha_usuario_NUTRYON_aqui

# JPA / Hibernate
# none  → sem ação do Hibernate (DDL já foi executado manualmente / pelo Flyway)
# validate → valida estrutura do banco contra as entidades (ativo quando Flyway rodar)
SPRING_JPA_HIBERNATE_DDL_AUTO=none
SPRING_JPA_SHOW_SQL=false

# Flyway
# false → DDL já executado manualmente no Oracle Cloud — desabilitar Flyway para testes
# true  → habilitar após confirmar que as migrations rodam corretamente no Oracle Cloud
SPRING_FLYWAY_ENABLED=false
SPRING_FLYWAY_BASELINE_ON_MIGRATE=true
SPRING_FLYWAY_VALIDATE_ON_MIGRATE=false

# JWT — use uma string longa e aleatória em produção
# Gere com (Git Bash/WSL): openssl rand -hex 64
# Ou use qualquer string com 64+ caracteres aleatórios
JWT_SECRET=troque_por_uma_string_secreta_longa_e_aleatoria_com_64_ou_mais_caracteres_aqui

# CORS — origens permitidas separadas por vírgula (sem espaços)
CORS_ALLOWED_ORIGINS=https://ashy-ground-044d2c50f.azurestaticapps.net,http://localhost:4200

# HikariCP — opcional, ajuste conforme necessidade
# HIKARI_MAX_POOL_SIZE=5
# HIKARI_MIN_IDLE=2
